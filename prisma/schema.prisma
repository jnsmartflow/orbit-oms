}

// ─────────────────────────────────────────────
// MAIL ORDER SYSTEM (mo_* tables)
// ─────────────────────────────────────────────

model mo_orders {
  id               Int       @id @default(autoincrement())
  soName           String
  soEmail          String?
  receivedAt       DateTime
  subject          String
  customerName     String?
  customerCode     String?
  deliveryRemarks  String?
  remarks          String?
  billRemarks      String?
  soNumber         String?
  dispatchStatus   String?   @default("Dispatch")
  dispatchPriority String?   @default("Normal")
  shipToOverride   Boolean?  @default(false)
  slotToOverride       Boolean?  @default(false)
  customerMatchStatus  String?   @default("unmatched")
  customerCandidates   String?
  status               String    @default("pending")
  punchedById      Int?
  punchedBy        users?    @relation("MoOrderPunchedBy", fields: [punchedById], references: [id])
  punchedAt        DateTime?
  emailEntryId     String    @unique
  totalLines       Int       @default(0)
  matchedLines     Int       @default(0)
  splitFromId      Int?
  splitLabel       String?
  createdAt        DateTime  @default(now())
  lines            mo_order_lines[]
  remarks_list     mo_order_remarks[]
}

model mo_order_lines {
  id                 Int       @id @default(autoincrement())
  moOrderId          Int
  moOrder            mo_orders @relation(fields: [moOrderId], references: [id], onDelete: Cascade)
  lineNumber         Int
  originalLineNumber Int?
  rawText            String
  packCode        String?
  quantity        Int       @default(0)
  productName     String?
  baseColour      String?
  skuCode         String?
  skuDescription  String?
  refSkuCode      String?
  paintType       String?
  materialType    String?
  matchStatus     String    @default("unmatched")
  createdAt       DateTime  @default(now())
}

model mo_product_keywords {
  id        Int      @id @default(autoincrement())
  keyword   String
  category  String
  product   String
  createdAt DateTime @default(now())
}

model mo_base_keywords {
  id         Int      @id @default(autoincrement())
  keyword    String
  category   String
  baseColour String
  createdAt  DateTime @default(now())
}

model mo_sku_lookup {
  id          Int      @id @default(autoincrement())
  material    String   @unique
  description String
  category    String
  product     String
  baseColour  String
  packCode    String
  unit         String?
  refMaterial  String?
  paintType    String?
  materialType String?
  createdAt    DateTime @default(now())
}

model mo_customer_keywords {
  id           Int      @id @default(autoincrement())
  customerCode String
  customerName String
  area         String?
  deliveryType String?
  route        String?
  keyword      String
  createdAt    DateTime @default(now())
}

model mo_order_remarks {
  id         Int      @id @default(autoincrement())
  moOrderId  Int
  lineNumber Int
  rawText    String
  remarkType String   @default("unknown")
  detectedBy String   @default("unknown")
  createdAt  DateTime @default(now())

  order mo_orders @relation(fields: [moOrderId], references: [id], onDelete: Cascade)

  @@index([moOrderId])
}
