model mo_order_lines {
  id                 Int       @id @default(autoincrement())
  moOrderId          Int
  moOrder            mo_orders @relation(fields: [moOrderId], references: [id], onDelete: Cascade)
  lineNumber         Int
  originalLineNumber Int?
  rawText            String
  packCode           String?
  quantity           Int       @default(0)
  productName        String?
  baseColour         String?
  skuCode            String?
  skuDescription     String?
  refSkuCode         String?
  paintType          String?
  materialType       String?
  matchStatus        String    @default("unmatched")
  isCarton           Boolean   @default(false)
  cartonCount        Int?
  createdAt          DateTime  @default(now())

  lineStatus mo_line_status?
}

model mo_product_keywords {
  id        Int      @id @default(autoincrement())
  keyword   String
  category  String
  product   String
  createdAt DateTime @default(now())
}

model mo_base_keywords {
  id         Int      @id @default(autoincrement())
  keyword    String
  category   String
  baseColour String
  createdAt  DateTime @default(now())
}

model mo_sku_lookup {
  id              Int      @id @default(autoincrement())
  material        String   @unique
  description     String
  category        String
  product         String
  baseColour      String
  packCode        String
  unit            String?
  refMaterial     String?
  refDescription  String?
  paintType       String?
  materialType    String?
  piecesPerCarton Int?
  createdAt       DateTime @default(now())
}

// Parallel v2 SKU lookup table — drives /place-order under the May 6 33-family
// taxonomy redesign. category/product hold v2 family/subProduct names.
// Live mo_sku_lookup continues to drive /order, parser, and enrichment.
// See docs/prompts/drafts/session-end-2026-05-10-recovery-and-branch-hygiene.md
model mo_sku_lookup_v2 {
  id              Int      @id @default(autoincrement())
  material        String   @unique
  description     String
  category        String
  product         String
  baseColour      String
  packCode        String
  unit            String?
  refMaterial     String?
  refDescription  String?
  paintType       String?
  materialType    String?
  piecesPerCarton Int?
  createdAt       DateTime @default(now())
  isPrimary       Boolean  @default(true)

  @@map("mo_sku_lookup_v2")
}

model mo_customer_keywords {
  id           Int      @id @default(autoincrement())
  customerCode String
  customerName String
  area         String?
  deliveryType String?
  route        String?
  keyword      String
  createdAt    DateTime @default(now())
}

model mo_order_remarks {
  id         Int      @id @default(autoincrement())
  moOrderId  Int
  lineNumber Int
  rawText    String
  remarkType String   @default("unknown")
  detectedBy String   @default("unknown")
  createdAt  DateTime @default(now())

  order mo_orders @relation(fields: [moOrderId], references: [id], onDelete: Cascade)

  @@index([moOrderId])
}

model mo_line_status {
  id                Int      @id @default(autoincrement())
  lineId            Int      @unique
  found             Boolean  @default(true)
  reason            String?
  altSkuCode        String?
  altSkuDescription String?
  note              String?
  updatedBy         Int?
  updatedAt         DateTime @default(now())

  line mo_order_lines @relation(fields: [lineId], references: [id], onDelete: Cascade)
  user users?         @relation(fields: [updatedBy], references: [id])
}

model mo_learned_customers {
  id              Int      @id @default(autoincrement())
  normalizedText  String
  customerCode    String
  hitCount        Int      @default(1)
  operators       String   @default("[]")
  lastConfirmedAt DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([normalizedText, customerCode])
}

model mo_order_form_index {
  id           Int      @id @default(autoincrement())
  family       String
  subProduct   String
  baseColour   String?
  displayName  String
  searchTokens String
  tinterType   String?
  productType  String?  @default("PLAIN")
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Widened from (subProduct, baseColour) to (family, subProduct, baseColour)
  // for Phase 1 taxonomy redesign — same (subProduct, baseColour) needs to
  // appear under multiple families when a Promise primer is cross-listed in
  // PRIMER + PROMISE INTERIOR + PROMISE umbrella. Migration SQL lives at
  // scripts/phase1-taxonomy-unique-constraint.sql; not yet applied.
  @@unique([family, subProduct, baseColour])
  @@map("mo_order_form_index")
}

// Parallel v2 catalog table — drives /place-order under the May 6 33-family
// taxonomy redesign. Live mo_order_form_index drives /order (mobile).
// After /place-order is approved on v2, /order will switch to v2 too and the
// legacy table can be dropped.
// See docs/prompts/drafts/session-end-2026-05-10-recovery-and-branch-hygiene.md
model mo_order_form_index_v2 {
  id           Int      @id @default(autoincrement())
  family       String
  subProduct   String
  product      String?   // Real product name — used for email, parser,
                         // dispatch. NULL during Phase 2 migration,
                         // becomes NOT NULL in Phase 4.
  uiGroup      String?   // Tab label on /place-order — frontend only.
                         // NULL during Phase 2 migration, becomes
                         // NOT NULL in Phase 4.
  baseColour   String?
  displayName  String
  searchTokens String
  tinterType   String?
  productType  String?  @default("PLAIN")
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  section      String
  subgroup     String
  mobileFamily String?
  region       String?   // optional grey per-row region label (Tools); NULL for paint
  createdAt    DateTime @default(now())

  @@unique([family, subProduct, baseColour])
  @@map("mo_order_form_index_v2")
}

model import_shadow_log {
  id            Int      @id @default(autoincrement())
  batchId       Int
  obdNumber     String
  source        String
  actualOutcome String
  shadowOutcome String
  decision      Json
  errors        String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([batchId], map: "idx_import_shadow_log_batch")
  @@index([obdNumber], map: "idx_import_shadow_log_obd")
  @@index([createdAt], map: "idx_import_shadow_log_created")
}

// ─────────────────────────────────────────────
// ATTENDANCE (v27.0) — records, summary, settings
// ─────────────────────────────────────────────

model attendance_records {
  id                     Int       @id @default(autoincrement())
  userId                 Int
  user                   users     @relation("AttendanceUser", fields: [userId], references: [id])
  type                   String
  timestamp              DateTime  @db.Timestamptz(6)
  attendanceDate         String
  sessionId              Int?
  latitude               Decimal?  @db.Decimal(10, 7)
  longitude              Decimal?  @db.Decimal(10, 7)
  locationAccuracyMeters Int?
  locationVerified       Boolean   @default(false)
  locationDistanceMeters Int?
  photoPath              String?
  photoSizeBytes         Int?
  userAgent              String?
  ipAddress              String?
  deviceLabel            String?
  isManualEntry          Boolean   @default(false)
  manualReason           String?
  createdById            Int?
  createdBy              users?    @relation("AttendanceCreatedBy", fields: [createdById], references: [id])
  isLate                 Boolean   @default(false)
  isOvertime             Boolean   @default(false)
  isOutsideGeofence      Boolean   @default(false)
  hasNoPhoto             Boolean   @default(false)
  hasNoLocation          Boolean   @default(false)
  createdAt              DateTime  @default(now()) @db.Timestamptz(6)
  // OT (overtime) approval fields
  otClaimed              Boolean?
  otClaimReason          String?
  otTotalLessThan95      Boolean?
  otApprovalStatus       String?
  otMinutesCredited      Int?      @default(0)
  otApprovedById         Int?
  otApprovedBy           users?    @relation("AttendanceOtApprover", fields: [otApprovedById], references: [id], onDelete: SetNull)
  otApprovedAt           DateTime? @db.Timestamptz(6)
  otAdminNote            String?
  otAudits               attendance_ot_audit[]

  @@index([userId, attendanceDate])
  @@index([attendanceDate])
  @@index([type, attendanceDate])
  @@index([otApprovalStatus, attendanceDate])
}

model attendance_summary {
  id                   Int       @id @default(autoincrement())
  userId               Int
  user                 users     @relation(fields: [userId], references: [id])
  attendanceDate       String
  firstCheckInAt       DateTime? @db.Timestamptz(6)
  lastCheckOutAt       DateTime? @db.Timestamptz(6)
  sessionCount         Int       @default(0)
  totalMinutesWorked   Int       @default(0)
  overtimeMinutes      Int       @default(0)
  lateMinutes          Int       @default(0)
  status               String    @default("ABSENT")
  exceptionReason      String?
  hasMissingCheckout   Boolean   @default(false)
  hasGeofenceViolation Boolean   @default(false)
  hasManualEntries     Boolean   @default(false)
  // OT (overtime) day-level rollup
  otMinutesCredited    Int       @default(0)
  otApprovalState      String?
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([userId, attendanceDate])
  @@index([attendanceDate])
  @@index([status, attendanceDate])
}

model attendance_settings {
  id                      Int      @id @default(autoincrement())
  scope                   String   @default("GLOBAL")
  roleSlug                String?
  rolloutStage            String   @default("OFF")
  workStartTime           String   @default("09:30")
  workEndTime             String   @default("19:00")
  lateGraceMinutes        Int      @default(15)
  halfDayThresholdMinutes Int      @default(240)
  checkInWindowStart      String   @default("08:00")
  checkInWindowEnd        String   @default("23:59")
  geofenceLat             Decimal  @default(21.1702000) @db.Decimal(10, 7)
  geofenceLng             Decimal  @default(72.8311000) @db.Decimal(10, 7)
  geofenceRadiusMeters    Int      @default(150)
  requirePhoto            Boolean  @default(true)
  requireLocation         Boolean  @default(true)
  photoRetentionDays      Int      @default(90)
  photoMaxWidthPx         Int      @default(640)
  photoJpegQuality        Int      @default(70)
  dpdpConsentVersion      String   @default("v1.0")
  // OT (overtime) policy knobs
  depotWorkingMinutes     Int      @default(570)
  otTriggerTime           String   @default("19:00")
  otMonthlyGraceLimit     Int      @default(3)
  otPromptEnabled         Boolean  @default(true)
  updatedAt               DateTime @updatedAt @db.Timestamptz(6)
  updatedById             Int?
  updatedBy               users?   @relation(fields: [updatedById], references: [id])

  @@unique([scope, roleSlug])
}

// ─────────────────────────────────────────────
// ATTENDANCE OT — grace counters + audit log
// ─────────────────────────────────────────────

model attendance_ot_grace {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      users    @relation("AttendanceOtGraceUser", fields: [userId], references: [id], onDelete: Cascade)
  yearMonth String
  flagCount Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @default(now()) @db.Timestamptz(6)

  @@unique([userId, yearMonth])
  @@index([yearMonth])
}

model attendance_ot_audit {
  id            Int                @id @default(autoincrement())
  recordId      Int
  record        attendance_records @relation(fields: [recordId], references: [id], onDelete: Cascade)
  userId        Int
  user          users              @relation("AttendanceOtAuditUser", fields: [userId], references: [id], onDelete: Cascade)
  action        String
  performedById Int
  performedBy   users              @relation("AttendanceOtAuditPerformer", fields: [performedById], references: [id], onDelete: Restrict)
  performedAt   DateTime           @default(now()) @db.Timestamptz(6)
  fromStatus    String?
  toStatus      String?
  note          String?

  @@index([recordId])
  @@index([userId, performedAt(sort: Desc)])
}
