  @@map("shade_master")
}

// ─────────────────────────────────────────────
// SAMPLING LIBRARY (Phase 1 — read + search)
// ─────────────────────────────────────────────

model sampling_register {
  samplingNo     String                 @id
  shadeName      String
  tinterType     TinterType
  siteId         Int?
  siteNameRaw    String?
  salesOfficerId Int?
  dealerName     String?
  notes          String?
  isActive       Boolean                @default(true)
  needsReview    Boolean                @default(false)
  createdById    Int
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt

  site                   delivery_point_master?   @relation(fields: [siteId], references: [id])
  salesOfficer           sales_officer_master?    @relation(fields: [salesOfficerId], references: [id])
  createdBy              users                    @relation("SamplingRegisterCreatedBy", fields: [createdById], references: [id])
  recipes                sampling_recipes[]
  usageLog               sampling_usage_log[]
  tinter_issue_entries   tinter_issue_entries[]   @relation("TinterIssueSampling")
  tinter_issue_entries_b tinter_issue_entries_b[] @relation("TinterIssueBSampling")

  @@index([tinterType, isActive])
  @@index([needsReview])
  @@index([siteId])
  @@index([salesOfficerId])
  @@index([shadeName])
}

model sampling_recipes {
  id          Int       @id @default(autoincrement())
  samplingNo  String
  skuCode     String
  productName String?
  packCode    PackCode?
  tinQty      Decimal   @default(0)
  // 13 TINTER pigment columns
  YOX         Decimal   @default(0)
  LFY         Decimal   @default(0)
  GRN         Decimal   @default(0)
  TBL         Decimal   @default(0)
  WHT         Decimal   @default(0)
  MAG         Decimal   @default(0)
  FFR         Decimal   @default(0)
  BLK         Decimal   @default(0)
  OXR         Decimal   @default(0)
  HEY         Decimal   @default(0)
  HER         Decimal   @default(0)
  COB         Decimal   @default(0)
  COG         Decimal   @default(0)
  // 14 ACOTONE pigment columns
  YE2         Decimal   @default(0)
  YE1         Decimal   @default(0)
  XY1         Decimal   @default(0)
  XR1         Decimal   @default(0)
  WH1         Decimal   @default(0)
  RE2         Decimal   @default(0)
  RE1         Decimal   @default(0)
  OR1         Decimal   @default(0)
  NO2         Decimal   @default(0)
  NO1         Decimal   @default(0)
  MA1         Decimal   @default(0)
  GR1         Decimal   @default(0)
  BU2         Decimal   @default(0)
  BU1         Decimal   @default(0)
  isPrimary   Boolean   @default(false)
  usageCount  Int       @default(0)
  firstUsedAt DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  sampling sampling_register @relation(fields: [samplingNo], references: [samplingNo])
  usageLog sampling_usage_log[]

  @@unique([samplingNo, skuCode, packCode])
  @@index([samplingNo])
  @@index([skuCode, packCode])
  @@index([lastUsedAt(sort: Desc)])
  @@index([samplingNo, isPrimary])
}

model sampling_usage_log {
  id              Int       @id @default(autoincrement())
  samplingNo      String
  recipeId        Int?
  usageDate       DateTime? @db.Date
  operatorId      Int?
  operatorNameRaw String?
  tinQty          Decimal   @default(0)
  dealerNameRaw   String?
  siteId          Int?
  siteNameRaw     String?
  skuCodeRaw      String?
  packCode        PackCode?
  deliveryNumber  String?   @db.Text
  sourceRowIndex  Int?
  createdAt       DateTime  @default(now())

  sampling sampling_register      @relation(fields: [samplingNo], references: [samplingNo], onDelete: Cascade)
  recipe   sampling_recipes?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  operator users?                 @relation("SamplingUsageOperator", fields: [operatorId], references: [id])
  site     delivery_point_master? @relation(fields: [siteId], references: [id])

  @@index([samplingNo])
  @@index([samplingNo, usageDate(sort: Desc)])
  @@index([operatorId, usageDate])
  @@index([siteNameRaw])
  @@index([siteId], map: "idx_sampling_usage_log_site")
}

// ─────────────────────────────────────────────
// MAIL ORDER SYSTEM (mo_* tables)
// ─────────────────────────────────────────────

model mo_orders {
