generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum StatusDomain {
  dispatch
  tinting
  pick_list
  import
  workflow
  priority
}

enum SlotRuleType {
  time_based
  default
}

enum TinterType {
  TINTER
  ACOTONE
}

enum PackCode {
  ml_500  @map("500ml")
  L_0_9   @map("0.9L")
  L_0_925 @map("0.925L")
  L_1     @map("1L")
  L_3_6   @map("3.6L")
  L_3_7   @map("3.7L")
  L_4     @map("4L")
  L_9     @map("9L")
  L_9_25  @map("9.25L")
  L_10    @map("10L")
  L_15    @map("15L")
  L_18    @map("18L")
  L_18_5  @map("18.5L")
  L_20    @map("20L")
  L_22    @map("22L")
  L_30    @map("30L")
  L_40    @map("40L")
}

enum CustomerSalesOfficerRole {
  PRIMARY
  BACKUP
  JUNIOR
}

// ─────────────────────────────────────────────
// PHASE 1 — Config / Status
// ─────────────────────────────────────────────

model system_config {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model role_master {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  users       users[]
  userRoles   user_roles[]
}

model user_roles {
  id          Int      @id @default(autoincrement())
  userId      Int
  roleId      Int
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdById Int?

  user      users       @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role      role_master @relation(fields: [roleId], references: [id])
  createdBy users?      @relation("UserRoleCreator", fields: [createdById], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model role_permissions {
  id        Int      @id @default(autoincrement())
  roleSlug  String // matches ROLES constants: "admin","dispatcher","support","tint_manager","tint_operator","floor_supervisor","picker"
  pageKey   String // e.g. "support_queue", "tint_manager", "import_obd", "customers", etc.
  canView   Boolean  @default(false)
  canImport Boolean  @default(false)
  canExport Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([roleSlug, pageKey])
}

model users {
  id                        Int                      @id @default(autoincrement())
  email                     String                   @unique
  phone                     String?                  @unique
  password                  String
  name                      String
  roleId                    Int
  role                      role_master              @relation(fields: [roleId], references: [id])
  isActive                  Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  // Attendance fields (v27.0 + v27.1 rollout flag)
  attendanceConsentAt       DateTime?                @db.Timestamptz(6)
  attendanceConsentVersion  String?
  attendanceExempt          Boolean                  @default(false)
  attendanceTestUser        Boolean                  @default(false)
  // Phase 2 back-relations
  importBatches             import_batches[]
  statusLogs                order_status_logs[]
  manualTintEntries         manual_tint_entries[]    @relation("ManualTintEntryPerformedBy")
  tintAssignmentsAsOperator tint_assignments[]       @relation("TintAssignmentOperator")
  tintAssignmentsAsManager  tint_assignments[]       @relation("TintAssignmentManager")
  tintLogs                  tint_logs[]
  // Phase 3 back-relations
  splitsAsOperator          order_splits[]           @relation("SplitOperator")
  splitsAsManager           order_splits[]           @relation("SplitManager")
  splitStatusLogs           split_status_logs[]      @relation("SplitStatusLogUser")
  tinterIssueEntries        tinter_issue_entries[]
  tinterIssueEntriesB       tinter_issue_entries_b[]
  shadeMasters              shade_master[]
  // Phase 3.5 back-relations
  challansPrinted           delivery_challans[]      @relation("ChallanPrintedBy")
  // Phase 4 back-relations
  plansCreated              dispatch_plans[]         @relation("PlanCreatedBy")
  plansConfirmed            dispatch_plans[]         @relation("PlanConfirmedBy")
  plansDispatched           dispatch_plans[]         @relation("PlanDispatchedBy")
  dispatchPlanOrders        dispatch_plan_orders[]   @relation("DPOrderAddedBy")
  pickListsAsPicker         pick_lists[]             @relation("PickListPicker")
  pickListsAssigned         pick_lists[]             @relation("PickListAssignedBy")
  pickListsVerified         pick_lists[]             @relation("PickListVerifiedBy")
  changesCreated            dispatch_change_queue[]  @relation("ChangeCreatedBy")
  changesAcknowledged       dispatch_change_queue[]  @relation("ChangeAcknowledgedBy")
  splitsPickedBy            order_splits[]           @relation("SplitPickedBy")
  ordersPickedBy            orders[]                 @relation("OrderPickedBy")
  pickAssignmentsAsPicker   pick_assignments[]       @relation("PickAssignmentPicker")
  pickAssignmentsAssigned   pick_assignments[]       @relation("PickAssignmentAssignedBy")
  // Mail Order back-relations
  mailOrdersPunched         mo_orders[]              @relation("MoOrderPunchedBy")
  lineStatuses              mo_line_status[]
  // Multi-role back-relations
  userRoles                 user_roles[]             @relation("UserRoleAssignments")
  userRolesCreated          user_roles[]             @relation("UserRoleCreator")
  // Attendance back-relations (v27.0)
  attendanceRecords         attendance_records[]     @relation("AttendanceUser")
  attendanceRecordsCreated  attendance_records[]     @relation("AttendanceCreatedBy")
  attendanceSummaries       attendance_summary[]
  attendanceSettingsUpdated attendance_settings[]
  // OT (overtime) approval back-relations
  attendanceOtApprovals        attendance_records[]  @relation("AttendanceOtApprover")
  attendanceOtGraceCounters    attendance_ot_grace[] @relation("AttendanceOtGraceUser")
  attendanceOtAudits           attendance_ot_audit[] @relation("AttendanceOtAuditUser")
  attendanceOtAuditsPerformed  attendance_ot_audit[] @relation("AttendanceOtAuditPerformer")
  // TM Remove OBD / Operator Skip / Pause back-relations
  ordersRemoved                orders[]              @relation("OrderRemovedBy")
  ordersRestored               orders[]              @relation("OrderRestoredBy")
  tintSkipsAsActor             tint_skip_events[]    @relation("SkipActor")
  tintPausesAsOp               tint_pause_events[]   @relation("PauseOperator")
  tintPauseResumes             tint_pause_events[]   @relation("PauseResumer")
  // Sampling Library back-relations
  samplingRegisterCreated      sampling_register[]   @relation("SamplingRegisterCreatedBy")
  samplingUsageEntries         sampling_usage_log[]  @relation("SamplingUsageOperator")
}

model status_master {
  id          Int          @id @default(autoincrement())
  domain      StatusDomain
  code        String
  label       String
  sortOrder   Int
  isActive    Boolean      @default(true)
  description String?
  createdAt   DateTime     @default(now())

  @@unique([domain, code])
}

// ─────────────────────────────────────────────
// PHASE 1 — SKU Hierarchy
// ─────────────────────────────────────────────

model product_category {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  productNames product_name[]
  skus         sku_master[]
}

model product_name {
  id         Int              @id @default(autoincrement())
  name       String           @unique
  categoryId Int
  category   product_category @relation(fields: [categoryId], references: [id])
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  skus       sku_master[]
}

model base_colour {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  skus      sku_master[]
}

model sku_master {
  id                Int                          @id @default(autoincrement())
  skuCode           String                       @unique
  skuName           String
  productCategoryId Int
  productCategory   product_category             @relation(fields: [productCategoryId], references: [id])
  productNameId     Int
  productName       product_name                 @relation(fields: [productNameId], references: [id])
  baseColourId      Int
  baseColour        base_colour                  @relation(fields: [baseColourId], references: [id])
  packSize          String
  containerType     String
  unitsPerCarton    Int?
  isActive          Boolean                      @default(true)
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  // Phase 2 back-relation
  enrichedLineItems import_enriched_line_items[]
}

// ─────────────────────────────────────────────
// PHASE 1 — Transporter / Vehicle
// ─────────────────────────────────────────────

model transporter_master {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  contactPerson String?
  phone         String?
  email         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  vehicles      vehicle_master[]
}

// ─────────────────────────────────────────────
// PHASE 1 — Geography & Delivery
// ─────────────────────────────────────────────

model delivery_type_master {
  id                      Int                         @id @default(autoincrement())
  name                    String                      @unique
  createdAt               DateTime                    @default(now())
  areas                   area_master[]
  slotConfigs             delivery_type_slot_config[]
  dispatchDeliveryPoints  delivery_point_master[]     @relation("DispatchDeliveryType")
  reportingDeliveryPoints delivery_point_master[]     @relation("ReportingDeliveryType")
}

model slot_master {
  id                 Int                         @id @default(autoincrement())
  name               String                      @unique
  slotTime           String
  isNextDay          Boolean                     @default(false)
  isActive           Boolean                     @default(true)
  sortOrder          Int
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  slotConfigs        delivery_type_slot_config[]
  orders             orders[]                    @relation("OrderCurrentSlot")
  ordersOriginalSlot orders[]                    @relation("OrderOriginalSlot")
  ordersArrival      orders[]                    @relation("OrderArrivalSlot")
  dispatchPlans      dispatch_plans[]
}

model delivery_type_slot_config {
  id             Int                  @id @default(autoincrement())
  deliveryTypeId Int
  deliveryType   delivery_type_master @relation(fields: [deliveryTypeId], references: [id])
  slotId         Int
  slot           slot_master          @relation(fields: [slotId], references: [id])
  slotRuleType   SlotRuleType
  windowStart    String?
  windowEnd      String?
  isDefault      Boolean              @default(false)
  isActive       Boolean              @default(true)
  sortOrder      Int
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([deliveryTypeId, slotId])
}

model route_master {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  description           String?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  areaRoutes            area_route_map[]
  primaryAreas          area_master[]           @relation("AreaPrimaryRoute")
  customerPrimaryRoutes delivery_point_master[] @relation("CustomerPrimaryRoute")
}

model area_master {
  id             Int                     @id @default(autoincrement())
  name           String
  deliveryTypeId Int
  deliveryType   delivery_type_master    @relation(fields: [deliveryTypeId], references: [id])
  primaryRouteId Int?
  primaryRoute   route_master?           @relation("AreaPrimaryRoute", fields: [primaryRouteId], references: [id])
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  areaRoutes     area_route_map[]
  subAreas       sub_area_master[]
  deliveryPoints delivery_point_master[]
}

model area_route_map {
  id      Int          @id @default(autoincrement())
  areaId  Int
  area    area_master  @relation(fields: [areaId], references: [id])
  routeId Int
  route   route_master @relation(fields: [routeId], references: [id])

  @@unique([areaId, routeId])
}

model sub_area_master {
  id             Int                     @id @default(autoincrement())
  name           String
  areaId         Int
  area           area_master             @relation(fields: [areaId], references: [id])
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  deliveryPoints delivery_point_master[]
}

// ─────────────────────────────────────────────
// PHASE 1 — Sales Officer
// ─────────────────────────────────────────────

model sales_officer_master {
  id                      Int                       @id @default(autoincrement())
  name                    String
  employeeCode            String
  email                   String?                   @unique
  phone                   String?
  isActive                Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  deliveryPoints          delivery_point_master[]
  groups                  sales_officer_group[]
  samplingRegisterEntries sampling_register[]
  customerLinks           customer_sales_officers[] @relation("CustomerSOLinks")
  contactLinks            delivery_point_contacts[] @relation("ContactSOLinks")
}

model sales_officer_group {
  id             Int                     @id @default(autoincrement())
  name           String                  @unique
  salesOfficerId Int
  salesOfficer   sales_officer_master    @relation(fields: [salesOfficerId], references: [id])
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  customers      delivery_point_master[]
}

// ─────────────────────────────────────────────
// PHASE 1 — Customers
// ─────────────────────────────────────────────

model customer_type_master {
  id             Int                     @id @default(autoincrement())
  name           String                  @unique
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  deliveryPoints delivery_point_master[]

  @@map("customer_type_master")
}

model premises_type_master {
  id             Int                     @id @default(autoincrement())
  name           String                  @unique
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  deliveryPoints delivery_point_master[]

  @@map("premises_type_master")
}

model contact_role_master {
  id        Int                       @id @default(autoincrement())
  name      String                    @unique
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  contacts  delivery_point_contacts[]
}

model delivery_point_master {
  id                      Int                       @id @default(autoincrement())
  customerCode            String                    @unique
  customerName            String
  areaId                  Int
  area                    area_master               @relation(fields: [areaId], references: [id])
  subAreaId               Int?
  subArea                 sub_area_master?          @relation(fields: [subAreaId], references: [id])
  salesOfficerId          Int?
  salesOfficer            sales_officer_master?     @relation(fields: [salesOfficerId], references: [id])
  primaryRouteId          Int?
  primaryRoute            route_master?             @relation("CustomerPrimaryRoute", fields: [primaryRouteId], references: [id])
  dispatchDeliveryTypeId  Int?
  dispatchDeliveryType    delivery_type_master?     @relation("DispatchDeliveryType", fields: [dispatchDeliveryTypeId], references: [id])
  reportingDeliveryTypeId Int?
  reportingDeliveryType   delivery_type_master?     @relation("ReportingDeliveryType", fields: [reportingDeliveryTypeId], references: [id])
  customerTypeId          Int?
  customerType            customer_type_master?     @relation(fields: [customerTypeId], references: [id])
  premisesTypeId          Int?
  premisesType            premises_type_master?     @relation(fields: [premisesTypeId], references: [id])
  salesOfficerGroupId     Int?
  salesOfficerGroup       sales_officer_group?      @relation(fields: [salesOfficerGroupId], references: [id])
  address                 String?
  customerRating          String?
  isKeyCustomer           Boolean                   @default(false)
  isKeySite               Boolean                   @default(false)
  acceptsPartialDelivery  Boolean                   @default(true)
  workingHoursStart       String?
  workingHoursEnd         String?
  noDeliveryDays          String[]
  latitude                Float?
  longitude               Float?
  isActive                Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  contacts                delivery_point_contacts[]
  // Phase 2 back-relation
  orders                  orders[]
  // Sampling Library back-relation
  samplingRegisterEntries sampling_register[]
  samplingUsageLogEntries sampling_usage_log[]
  // Phase 1 multi-SO back-relation
  salesOfficerLinks       customer_sales_officers[]
}

model delivery_point_contacts {
  id                   Int                   @id @default(autoincrement())
  deliveryPointId      Int
  deliveryPoint        delivery_point_master @relation(fields: [deliveryPointId], references: [id])
  name                 String
  phone                String?
  email                String?
  isPrimary            Boolean               @default(false)
  contactRoleId        Int?
  contactRole          contact_role_master?  @relation(fields: [contactRoleId], references: [id])
  linkedSalesOfficerId Int?
  linkedSalesOfficer   sales_officer_master? @relation("ContactSOLinks", fields: [linkedSalesOfficerId], references: [id])
  createdAt            DateTime              @default(now())
}

model customer_sales_officers {
  id               Int                      @id @default(autoincrement())
  customerId       Int
  customer         delivery_point_master    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesOfficerId   Int
  salesOfficer     sales_officer_master     @relation("CustomerSOLinks", fields: [salesOfficerId], references: [id])
  role             CustomerSalesOfficerRole @default(PRIMARY)
  contactDismissed Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([customerId, salesOfficerId])
  @@index([salesOfficerId])
  @@index([customerId, role])
  // Partial UNIQUE INDEX (customerId) WHERE role = 'PRIMARY'
  // exists in Supabase only — Prisma cannot model partial indexes.
}

// ─────────────────────────────────────────────
// PHASE 2 — Import tables (5)
// ─────────────────────────────────────────────

model import_batches {
  id           Int                  @id @default(autoincrement())
  batchRef     String               @unique
  importedById Int
  importedBy   users                @relation(fields: [importedById], references: [id])
  headerFile   String
  lineFile     String
  totalObds    Int                  @default(0)
  skippedObds  Int                  @default(0)
  failedObds   Int                  @default(0)
  status       String               @default("processing")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  rawSummaries import_raw_summary[]
  orders       orders[]
}

model import_raw_summary {
  id                  Int                     @id @default(autoincrement())
  batchId             Int
  batch               import_batches          @relation(fields: [batchId], references: [id])
  obdNumber           String
  sapStatus           String?
  smu                 String?
  smuCode             String?
  materialType        String?
  natureOfTransaction String?
  warehouse           String?
  obdEmailDate        DateTime?
  obdEmailTime        String?
  totalUnitQty        Int?
  grossWeight         Float?
  volume              Float?
  billToCustomerId    String?
  billToCustomerName  String?
  shipToCustomerId    String?
  shipToCustomerName  String?
  invoiceNo           String?
  soNumber            String?
  invoiceDate         DateTime?
  smuNumber           String?
  rowStatus           String                  @default("valid")
  rowError            String?
  createdAt           DateTime                @default(now())
  rawLineItems        import_raw_line_items[]
}

model import_raw_line_items {
  id                  Int                         @id @default(autoincrement())
  rawSummaryId        Int
  rawSummary          import_raw_summary          @relation(fields: [rawSummaryId], references: [id])
  obdNumber           String
  lineId              Int
  skuCodeRaw          String
  skuDescriptionRaw   String?
  batchCode           String?
  unitQty             Int
  volumeLine          Float?
  netWeight           Float?
  totalWeight         Float?
  isTinting           Boolean                     @default(false)
  article             Int?
  articleTag          String?
  rowStatus           String                      @default("valid")
  rowError            String?
  createdAt           DateTime                    @default(now())
  lineStatus          String                      @default("active")
  removedAt           DateTime?                   @db.Timestamptz(6)
  removedReason       String?
  enrichedLineItem    import_enriched_line_items?
  splitLineItems      split_line_items[]
  challanFormulas     delivery_challan_formulas[]
  tinterIssueEntries  tinter_issue_entries[]
  tinterIssueEntriesB tinter_issue_entries_b[]
}

model import_enriched_line_items {
  id            Int                   @id @default(autoincrement())
  rawLineItemId Int                   @unique
  rawLineItem   import_raw_line_items @relation(fields: [rawLineItemId], references: [id])
  skuId         Int?
  sku           sku_master?           @relation(fields: [skuId], references: [id])
  unitQty       Int
  volumeLine    Float?
  lineWeight    Float?
  isTinting     Boolean
  note          String?
  createdAt     DateTime              @default(now())
}

model import_obd_query_summary {
  id           Int      @id @default(autoincrement())
  obdNumber    String   @unique
  orderId      Int?     @unique
  order        orders?  @relation(fields: [orderId], references: [id])
  totalLines   Int
  totalUnitQty Int
  totalWeight  Float
  totalVolume  Float
  hasTinting   Boolean
  totalArticle Int      @default(0)
  articleTag   String?
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────
// PHASE 2 — Orders + Tinting + Support (5)
// ─────────────────────────────────────────────

model orders {
  id                   Int                       @id @default(autoincrement())
  obdNumber            String                    @unique
  batchId              Int
  batch                import_batches            @relation(fields: [batchId], references: [id])
  customerId           Int?
  customer             delivery_point_master?    @relation(fields: [customerId], references: [id])
  shipToCustomerId     String
  shipToCustomerName   String?
  orderType            String
  workflowStage        String                    @default("order_created")
  dispatchSlot         String?
  dispatchSlotDeadline DateTime?
  slotId               Int?
  slot                 slot_master?              @relation("OrderCurrentSlot", fields: [slotId], references: [id])
  originalSlotId       Int?
  originalSlot         slot_master?              @relation("OrderOriginalSlot", fields: [originalSlotId], references: [id])
  arrivalSlotId        Int?
  arrivalSlot          slot_master?              @relation("OrderArrivalSlot",  fields: [arrivalSlotId],  references: [id])
  priorityLevel        Int                       @default(3)
  dispatchStatus       String?
  invoiceNo            String?
  soNumber             String?
  invoiceDate          DateTime?
  obdEmailDate         DateTime?
  orderDateTime        DateTime?                 @db.Timestamptz(6)
  smu                  String?
  sapStatus            String?
  materialType         String?
  natureOfTransaction  String?
  warehouse            String?
  totalUnitQty         Int?
  grossWeight          Float?
  volume               Float?
  remarks              String?
  shipToOverride       Boolean                   @default(false)
  slotToOverride       Boolean                   @default(false)
  mailMatched          Boolean                   @default(false)
  customerMissing      Boolean                   @default(false)
  manualTintEntry      Boolean                   @default(false)
  isActive             Boolean                   @default(true)
  sequenceOrder        Int                       @default(0)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  querySnapshot        import_obd_query_summary?
  statusLogs           order_status_logs[]
  manualTintEntries    manual_tint_entries[]
  tintAssignments      tint_assignments[]
  tintLogs             tint_logs[]
  splits               order_splits[]
  tinterIssueEntries   tinter_issue_entries[]
  tinterIssueEntriesB  tinter_issue_entries_b[]
  challan              delivery_challans?
  // Phase 4 pick fields (for non-tinting orders without splits)
  isPicked             Boolean                   @default(false)
  pickedAt             DateTime?
  pickedById           Int?
  pickedBy             users?                    @relation("OrderPickedBy", fields: [pickedById], references: [id])
  // Phase 4 back-relations
  dispatchPlanOrders   dispatch_plan_orders[]
  pickListItems        pick_list_items[]
  changeQueue          dispatch_change_queue[]
  pickAssignment       pick_assignments?
  // TM Remove OBD (Feature 1)
  isRemoved            Boolean                   @default(false)
  removalReason        String?
  removalRemark        String?
  removedAt            DateTime?                 @db.Timestamptz(6)
  removedById          Int?
  removedBy            users?                    @relation("OrderRemovedBy", fields: [removedById], references: [id])
  restoredAt           DateTime?                 @db.Timestamptz(6)
  restoredById         Int?
  restoredBy           users?                    @relation("OrderRestoredBy", fields: [restoredById], references: [id])
  // Operator Skip / Pause back-relations (Features 2 & 3)
  skipEvents           tint_skip_events[]
  pauseEvents          tint_pause_events[]
  // Hide (Feature A — manual one-off hide)
  isHidden             Boolean                   @default(false)
  hiddenById           Int?
  hiddenReason         String?
  hiddenAt             DateTime?                 @db.Timestamptz(6)
}

// ─────────────────────────────────────────────
// HIDE FEATURE (OBD visibility) — 2026-06-12
// ─────────────────────────────────────────────

model obd_visibility_rules {
  id              Int       @id @default(autoincrement())
  ruleName        String
  conditionType   String // 'tag' | 'daysOld'
  conditionTag    String? // 'HOLD' | 'URGENT' | 'MISSING_CUSTOMER'
  conditionDaysGt Int?
  isActive        Boolean   @default(true)
  createdById     Int
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedById     Int?
  updatedAt       DateTime? @db.Timestamptz(6)

  @@index([isActive])
}

model app_tag_settings {
  id          Int       @id @default(autoincrement())
  tagKey      String    @unique
  isEnabled   Boolean   @default(true)
  updatedById Int?
  updatedAt   DateTime? @db.Timestamptz(6)
}

model order_splits {
  id                  Int                      @id @default(autoincrement())
  orderId             Int
  order               orders                   @relation(fields: [orderId], references: [id])
  splitNumber         Int
  assignedToId        Int
  assignedTo          users                    @relation("SplitOperator", fields: [assignedToId], references: [id])
  assignedById        Int
  assignedBy          users                    @relation("SplitManager", fields: [assignedById], references: [id])
  status              String                   @default("tint_assigned")
  dispatchStatus      String?
  priorityLevel       Int                      @default(3)
  dispatchSlot        String?
  totalQty            Int                      @default(0)
  totalVolume         Float?
  articleTag          String?
  note                String?
  sequenceOrder       Int                      @default(0)
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  tiSubmitted         Boolean                  @default(false)
  operatorSequence    Int                      @default(0)
  lineItems           split_line_items[]
  statusLogs          split_status_logs[]
  tintLogs            tint_logs[]
  tintAssignment      tint_assignments?
  tinterIssueEntries  tinter_issue_entries[]
  tinterIssueEntriesB tinter_issue_entries_b[]
  // Phase 4 pick fields
  isPicked            Boolean                  @default(false)
  pickedAt            DateTime?
  pickedById          Int?
  pickedBy            users?                   @relation("SplitPickedBy", fields: [pickedById], references: [id])
}

model split_line_items {
  id                Int                   @id @default(autoincrement())
  splitId           Int
  split             order_splits          @relation(fields: [splitId], references: [id])
  rawLineItemId     Int
  rawLineItem       import_raw_line_items @relation(fields: [rawLineItemId], references: [id])
  assignedQty       Int
  createdAt         DateTime              @default(now())
  lineStatus        String                @default("active")
  removedAt         DateTime?             @db.Timestamptz(6)
  removedReason     String?
  lastSeenInBatchId Int?
  pickListItems     pick_list_items[]

  @@index([lineStatus], map: "idx_split_line_items_status")
}

model split_status_logs {
  id          Int          @id @default(autoincrement())
  splitId     Int
  split       order_splits @relation(fields: [splitId], references: [id])
  fromStage   String?
  toStage     String
  changedById Int
  changedBy   users        @relation("SplitStatusLogUser", fields: [changedById], references: [id])
  note        String?
  createdAt   DateTime     @default(now())
}

model tint_assignments {
  id                  Int                      @id @default(autoincrement())
  orderId             Int
  order               orders                   @relation(fields: [orderId], references: [id])
  splitId             Int?                     @unique
  split               order_splits?            @relation(fields: [splitId], references: [id])
  assignedToId        Int
  assignedTo          users                    @relation("TintAssignmentOperator", fields: [assignedToId], references: [id])
  assignedById        Int
  assignedBy          users                    @relation("TintAssignmentManager", fields: [assignedById], references: [id])
  status              String                   @default("assigned")
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  tiSubmitted         Boolean                  @default(false)
  operatorSequence    Int                      @default(0)
  tinterIssueEntries  tinter_issue_entries[]
  tinterIssueEntriesB tinter_issue_entries_b[]
  // Operator Skip (Feature 2)
  skippedAt           DateTime?                @db.Timestamptz(6)
  skipEventId         BigInt?
  skipEvent           tint_skip_events?        @relation("AssignmentSkipEvent", fields: [skipEventId], references: [id])
  skipEventsTriggered tint_skip_events[]       @relation("AssignmentSkipEvents")
  // Operator Pause/Resume (Feature 3)
  pauseCount          Int                      @default(0)
  lastPausedAt        DateTime?                @db.Timestamptz(6)
  // On done, this field is finalised as the total tinting minutes including all paused intervals.
  accumulatedMinutes  Int                      @default(0)
  currentProgress     Json?
  pauseEvents         tint_pause_events[]
}

model tint_logs {
  id            Int           @id @default(autoincrement())
  orderId       Int
  order         orders        @relation(fields: [orderId], references: [id])
  splitId       Int?
  split         order_splits? @relation(fields: [splitId], references: [id])
  action        String
  performedById Int
  performedBy   users         @relation(fields: [performedById], references: [id])
  note          String?
  createdAt     DateTime      @default(now())
}

model order_status_logs {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       orders   @relation(fields: [orderId], references: [id])
  fromStage   String?
  toStage     String
  changedById Int
  changedBy   users    @relation(fields: [changedById], references: [id])
  note        String?
  createdAt   DateTime @default(now())
}

model manual_tint_entries {
  id            Int      @id @default(autoincrement())
  orderId       Int
  order         orders   @relation(fields: [orderId], references: [id])
  action        String // 'pulled_in' | 'reverted'
  reasonCode    String // 'sample' | 'custom_shade' | 'late_addition' | 'classification_miss' | 'other'
  reasonNotes   String?
  lineIds       Int[]
  performedById Int
  performedBy   users    @relation("ManualTintEntryPerformedBy", fields: [performedById], references: [id])
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([orderId])
  @@index([createdAt(sort: Desc)])
  @@index([action])
}

// ─────────────────────────────────────────────
// TINT SKIP / PAUSE EVENTS (Features 2 & 3)
// ─────────────────────────────────────────────

model tint_skip_events {
  id                BigInt             @id @default(autoincrement())
  orderId           Int
  order             orders             @relation(fields: [orderId], references: [id])
  assignmentId      Int
  assignment        tint_assignments   @relation("AssignmentSkipEvents", fields: [assignmentId], references: [id])
  skippedById       Int
  skippedBy         users              @relation("SkipActor", fields: [skippedById], references: [id])
  skippedAt         DateTime           @default(now()) @db.Timestamptz(6)
  reason            String
  tinterType        String?
  outOfStockColours String[]
  remark            String?
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  assignmentLinked  tint_assignments[] @relation("AssignmentSkipEvent")

  @@index([orderId])
  @@index([skippedAt(sort: Desc)])
}

model tint_pause_events {
  id                    BigInt           @id @default(autoincrement())
  orderId               Int
  order                 orders           @relation(fields: [orderId], references: [id])
  assignmentId          Int
  assignment            tint_assignments @relation(fields: [assignmentId], references: [id])
  operatorId            Int
  operator              users            @relation("PauseOperator", fields: [operatorId], references: [id])
  pausedAt              DateTime         @default(now()) @db.Timestamptz(6)
  pauseReason           String
  tinterType            String?
  outOfStockColours     String[]
  pauseRemark           String?
  progressSnapshot      Json
  elapsedMinutesAtPause Int
  resumedAt             DateTime?        @db.Timestamptz(6)
  resumedById           Int?
  resumedBy             users?           @relation("PauseResumer", fields: [resumedById], references: [id])
  resumeRemark          String?
  createdAt             DateTime         @default(now()) @db.Timestamptz(6)
}

// ─────────────────────────────────────────────
// PHASE 4 — Dispatch + Warehouse
// ─────────────────────────────────────────────

model vehicle_master {
  id                  Int                @id @default(autoincrement())
  vehicleNo           String             @unique
  category            String
  capacityKg          Float
  maxCustomers        Int?
  deliveryTypeAllowed String
  transporterId       Int
  transporter         transporter_master @relation(fields: [transporterId], references: [id])
  driverName          String?
  driverPhone         String?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  dispatchPlans       dispatch_plans[]
}

model dispatch_plans {
  id             Int                     @id @default(autoincrement())
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  planDate       DateTime                @db.Date
  slotId         Int
  slot           slot_master             @relation(fields: [slotId], references: [id])
  vehicleId      Int?
  vehicle        vehicle_master?         @relation(fields: [vehicleId], references: [id])
  tripNumber     Int                     @default(1) @db.SmallInt
  status         String                  @default("draft")
  totalOrders    Int                     @default(0)
  totalWeightKg  Float                   @default(0)
  totalVolume    Float                   @default(0)
  createdById    Int
  createdBy      users                   @relation("PlanCreatedBy", fields: [createdById], references: [id])
  confirmedAt    DateTime?
  confirmedById  Int?
  confirmedBy    users?                  @relation("PlanConfirmedBy", fields: [confirmedById], references: [id])
  dispatchedAt   DateTime?
  dispatchedById Int?
  dispatchedBy   users?                  @relation("PlanDispatchedBy", fields: [dispatchedById], references: [id])
  notes          String?
  orders         dispatch_plan_orders[]
  pickLists      pick_lists[]
  changeQueue    dispatch_change_queue[]

  @@unique([planDate, slotId, vehicleId, tripNumber])
}

model dispatch_plan_orders {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  planId        Int
  plan          dispatch_plans @relation(fields: [planId], references: [id], onDelete: Cascade)
  orderId       Int
  order         orders         @relation(fields: [orderId], references: [id])
  sequenceOrder Int            @default(0) @db.SmallInt
  addedById     Int
  addedBy       users          @relation("DPOrderAddedBy", fields: [addedById], references: [id])
  clearedAt     DateTime?      @db.Timestamptz

  @@unique([planId, orderId])
}

model pick_lists {
  id           Int               @id @default(autoincrement())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  planId       Int
  plan         dispatch_plans    @relation(fields: [planId], references: [id], onDelete: Cascade)
  pickerId     Int?
  picker       users?            @relation("PickListPicker", fields: [pickerId], references: [id])
  status       String            @default("pending_pick")
  assignedAt   DateTime?
  assignedById Int?
  assignedBy   users?            @relation("PickListAssignedBy", fields: [assignedById], references: [id])
  startedAt    DateTime?
  completedAt  DateTime?
  verifiedAt   DateTime?
  verifiedById Int?
  verifiedBy   users?            @relation("PickListVerifiedBy", fields: [verifiedById], references: [id])
  notes        String?
  items        pick_list_items[]
}

model pick_list_items {
  id              Int               @id @default(autoincrement())
  createdAt       DateTime          @default(now())
  pickListId      Int
  pickList        pick_lists        @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  splitLineItemId Int?
  splitLineItem   split_line_items? @relation(fields: [splitLineItemId], references: [id])
  orderId         Int
  order           orders            @relation(fields: [orderId], references: [id])
  skuCode         String?
  skuDescription  String?
  qtyRequired     Int               @default(0)
  qtyPicked       Int               @default(0)
  isPicked        Boolean           @default(false)
  isVerified      Boolean           @default(false)
  pickedAt        DateTime?
  verifiedAt      DateTime?
  notes           String?
}

model dispatch_change_queue {
  id               Int             @id @default(autoincrement())
  createdAt        DateTime        @default(now())
  orderId          Int
  order            orders          @relation(fields: [orderId], references: [id])
  planId           Int?
  plan             dispatch_plans? @relation(fields: [planId], references: [id], onDelete: SetNull)
  changeType       String          @default("hold")
  previousValue    String?
  newValue         String?
  changedById      Int
  changedBy        users           @relation("ChangeCreatedBy", fields: [changedById], references: [id])
  isAcknowledged   Boolean         @default(false)
  acknowledgedAt   DateTime?
  acknowledgedById Int?
  acknowledgedBy   users?          @relation("ChangeAcknowledgedBy", fields: [acknowledgedById], references: [id])
  notes            String?
}

model pick_assignments {
  id           Int       @id @default(autoincrement())
  orderId      Int       @unique @map("order_id")
  order        orders    @relation(fields: [orderId], references: [id])
  pickerId     Int       @map("picker_id")
  picker       users     @relation("PickAssignmentPicker", fields: [pickerId], references: [id])
  sequence     Int
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedById Int       @map("assigned_by_id")
  assignedBy   users     @relation("PickAssignmentAssignedBy", fields: [assignedById], references: [id])
  status       String    @default("assigned")
  pickedAt     DateTime? @map("picked_at")
  notes        String?
  clearedAt    DateTime? @db.Timestamptz
}

model tinter_issue_entries {
  id               Int        @id @default(autoincrement())
  orderId          Int
  splitId          Int?
  tintAssignmentId Int?
  submittedById    Int
  baseSku          String
  tinQty           Decimal    @default(0)
  YOX              Decimal    @default(0)
  LFY              Decimal    @default(0)
  GRN              Decimal    @default(0)
  TBL              Decimal    @default(0)
  WHT              Decimal    @default(0)
  MAG              Decimal    @default(0)
  FFR              Decimal    @default(0)
  BLK              Decimal    @default(0)
  OXR              Decimal    @default(0)
  HEY              Decimal    @default(0)
  HER              Decimal    @default(0)
  COB              Decimal    @default(0)
  COG              Decimal    @default(0)
  tinterType       TinterType @default(TINTER)
  packCode         PackCode?
  rawLineItemId    Int?
  samplingNo       String?
  shadeName        String?
  createdAt        DateTime   @default(now())

  order             orders                 @relation(fields: [orderId], references: [id])
  split             order_splits?          @relation(fields: [splitId], references: [id])
  tintAssignment    tint_assignments?      @relation(fields: [tintAssignmentId], references: [id])
  submittedBy       users                  @relation(fields: [submittedById], references: [id])
  rawLineItem       import_raw_line_items? @relation(fields: [rawLineItemId], references: [id])
  sampling_register sampling_register?     @relation("TinterIssueSampling", fields: [samplingNo], references: [samplingNo], onDelete: SetNull)

  @@index([samplingNo])
  @@map("tinter_issue_entries")
}

// ─────────────────────────────────────────────
// PHASE 3.5 — Delivery Challan (2)
// ─────────────────────────────────────────────

model delivery_challans {
  id            Int                         @id @default(autoincrement())
  orderId       Int                         @unique
  order         orders                      @relation(fields: [orderId], references: [id])
  challanNumber String                      @unique
  transporter   String?
  vehicleNo     String?
  printedAt     DateTime?
  printedBy     Int?
  printedByUser users?                      @relation("ChallanPrintedBy", fields: [printedBy], references: [id])
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  formulas      delivery_challan_formulas[]
  // TM Remove OBD — void fields (Feature 1)
  isVoided      Boolean                     @default(false)
  voidReason    String?
  voidRemark    String?
  voidedAt      DateTime?                   @db.Timestamptz(6)
}

model delivery_challan_formulas {
  id                   Int                   @id @default(autoincrement())
  challanId            Int
  challan              delivery_challans     @relation(fields: [challanId], references: [id])
  rawLineItemId        Int
  rawLineItem          import_raw_line_items @relation(fields: [rawLineItemId], references: [id])
  formula              String
  isManuallyOverridden Boolean               @default(false)
  autoFilledAt         DateTime?
  sourceTiEntryId      Int?
  updatedAt            DateTime              @updatedAt

  @@unique([challanId, rawLineItemId])
}

// ─────────────────────────────────────────────
// SHADE MASTER — Acotone TI + Shade Memory
// ─────────────────────────────────────────────

model tinter_issue_entries_b {
  id               Int        @id @default(autoincrement())
  orderId          Int
  splitId          Int?
  tintAssignmentId Int?
  submittedById    Int
  baseSku          String
  tinQty           Decimal    @default(0)
  YE2              Decimal    @default(0)
  YE1              Decimal    @default(0)
  XY1              Decimal    @default(0)
  XR1              Decimal    @default(0)
  WH1              Decimal    @default(0)
  RE2              Decimal    @default(0)
  RE1              Decimal    @default(0)
  OR1              Decimal    @default(0)
  NO2              Decimal    @default(0)
  NO1              Decimal    @default(0)
  MA1              Decimal    @default(0)
  GR1              Decimal    @default(0)
  BU2              Decimal    @default(0)
  BU1              Decimal    @default(0)
  tinterType       TinterType @default(ACOTONE)
  packCode         PackCode?
  rawLineItemId    Int?
  samplingNo       String?
  shadeName        String?
  createdAt        DateTime   @default(now())

