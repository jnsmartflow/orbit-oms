model shade_master {
  id                  Int        @id @default(autoincrement())
  shadeName           String
  shipToCustomerId    String
  shipToCustomerName  String
  tinterType          TinterType
  packCode            PackCode?
  skuCode             String?
  baseSku             String
  tinQty              Decimal    @default(0)
  // TINTER columns
  YOX                 Decimal?   @default(0)
  LFY                 Decimal?   @default(0)
  GRN                 Decimal?   @default(0)
  TBL                 Decimal?   @default(0)
  WHT                 Decimal?   @default(0)
  MAG                 Decimal?   @default(0)
  FFR                 Decimal?   @default(0)
  BLK                 Decimal?   @default(0)
  OXR                 Decimal?   @default(0)
  HEY                 Decimal?   @default(0)
  HER                 Decimal?   @default(0)
  COB                 Decimal?   @default(0)
  COG                 Decimal?   @default(0)
  // ACOTONE columns
  YE2                 Decimal?   @default(0)
  YE1                 Decimal?   @default(0)
  XY1                 Decimal?   @default(0)
  XR1                 Decimal?   @default(0)
  WH1                 Decimal?   @default(0)
  RE2                 Decimal?   @default(0)
  RE1                 Decimal?   @default(0)
  OR1                 Decimal?   @default(0)
  NO2                 Decimal?   @default(0)
  NO1                 Decimal?   @default(0)
  MA1                 Decimal?   @default(0)
  GR1                 Decimal?   @default(0)
  BU2                 Decimal?   @default(0)
  BU1                 Decimal?   @default(0)
  createdById         Int
  isActive            Boolean    @default(true)
